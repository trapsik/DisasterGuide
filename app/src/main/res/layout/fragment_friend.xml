<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".FriendFragment">

    <!-- TODO: Update blank fragment layout -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:focusable="true"
        android:focusableInTouchMode="true"
        android:id="@+id/parentLayout">

        <ImageView
            android:id="@+id/main_img"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:padding="5dp"
            android:src="@drawable/logo"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintLeft_toLeftOf="parent" />

        <TextView
            android:id="@+id/tv_title"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:text="친구 목록"
            android:paddingTop="5dp"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            android:textColor="#000000"
            android:textSize="25dp"
            android:textStyle="bold"/>
        <ImageView
            android:id="@+id/search_userID"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/search_post"
            android:layout_margin="3dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintRight_toRightOf="parent" />



        <ListView
            android:id="@+id/listFriend"
            android:layout_width="364dp"
            android:layout_height="280dp"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/tv_title"
            android:layout_marginTop="20dp"
            tools:listitem="@layout/item_listview_friend"
            android:divider="#dedede"
            android:dividerHeight="1dp"/>
        <View
            android:layout_width="364dp"
            android:layout_height="5dp"
            android:background="#dedede"
            app:layout_constraintTop_toBottomOf="@id/listFriend"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintRight_toRightOf="parent"
            android:layout_marginTop="5dp" />

        <ListView
            android:id="@+id/listFriendRequest"
            android:layout_width="364dp"
            android:layout_height="240dp"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/listFriend"
            android:layout_marginTop="15dp"
            tools:listitem="@layout/item_listview_friend_request"
            android:divider="#dedede"
            android:dividerHeight="1dp"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

</FrameLayout>