<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <ImageView
        android:id="@+id/back"
        android:layout_width="30dp"
        android:layout_height="30dp"
        android:src="@drawable/back"
        android:layout_margin="8dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintLeft_toLeftOf="parent" />
    <TextView
        android:id="@+id/tv_title"
        android:layout_width="wrap_content"
        android:layout_height="40dp"
        android:text="친구 요청 보내기"
        android:paddingTop="5dp"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:textColor="#000000"
        android:textSize="25dp"
        android:textStyle="bold"/>

    <EditText
        android:id="@+id/edtFriendID"
        android:layout_width="224dp"
        android:layout_height="wrap_content"
        android:layout_marginLeft="24dp"
        android:layout_marginTop="28dp"
        android:background="@drawable/edge"
        android:hint="ID로 친구 요청 보내기."
        android:padding="5dp"
        android:textColorHint="#CACACA"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_title" />

    <TextView
        android:id="@+id/searchFriend"
        android:layout_width="50dp"
        android:layout_height="33dp"
        android:background="@drawable/edge"
        android:gravity="center_horizontal|center_vertical"
        android:text="검색"
        android:textColor="#000000"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/tv_title"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toLeftOf="@id/addFriend"
        app:layout_constraintHorizontal_chainStyle="packed"
        android:layout_marginTop="30dp"
        android:layout_marginStart="264dp"/>

    <TextView
        android:id="@+id/addFriend"
        android:layout_width="50dp"
        android:layout_height="33dp"
        android:background="@drawable/edge"
        android:gravity="center_horizontal|center_vertical"
        android:text="전송"
        android:textColor="#000000"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/tv_title"
        app:layout_constraintLeft_toRightOf="@id/searchFriend"
        app:layout_constraintRight_toRightOf="parent"
        android:layout_marginTop="30dp"/>

    <TextView
        android:id="@+id/tv_searchPeopleInfo"
        android:layout_width="364dp"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toBottomOf="@id/edtFriendID"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        android:layout_marginTop="50dp"
        android:textStyle="bold"
        android:textSize="30sp"/>



</androidx.constraintlayout.widget.ConstraintLayout>