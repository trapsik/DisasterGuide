<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <ImageView
        android:id="@+id/back"
        android:layout_width="30dp"
        android:layout_height="30dp"
        android:src="@drawable/back"
        android:layout_margin="8dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintLeft_toLeftOf="parent" />

    <TextView
        android:id="@+id/listTitle"
        android:layout_width="wrap_content"
        android:layout_height="40dp"
        android:text="민방위대피소"
        android:paddingTop="5dp"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:textColor="#000000"
        android:textSize="25dp"
        android:textStyle="bold"/>

    <EditText
        android:layout_width="250dp"
        android:layout_height="30dp"
        android:id="@+id/cds_location"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toLeftOf="@+id/cds_searchLocation"
        android:layout_marginTop="50dp"
        android:background="@drawable/edge"
        android:hint="검색어를 입력해주세요"
        android:padding="5dp"
        android:textColorHint="#CACACA"/>

    <TextView
        android:layout_width="80dp"
        android:layout_height="30dp"
        android:id="@+id/cds_searchLocation"
        android:text="검색"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintLeft_toRightOf="@+id/cds_location"
        android:layout_marginTop="50dp"
        android:background="@drawable/edge"
        android:textColor="#000000"
        android:textStyle="bold"
        android:gravity="center_horizontal|center_vertical"/>

    <TextView
        android:layout_width="150dp"
        android:layout_height="30dp"
        android:id="@+id/cds_findNearLocation"
        android:text="주변 시설 조회"
        app:layout_constraintTop_toBottomOf="@+id/cds_location"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toLeftOf="@+id/cds_findNearestLocation"
        android:layout_marginTop="10dp"
        android:background="@drawable/edge"
        android:textColor="#000000"
        android:textStyle="bold"
        android:gravity="center_horizontal|center_vertical"/>

    <TextView
        android:layout_width="180dp"
        android:layout_height="30dp"
        android:id="@+id/cds_findNearestLocation"
        android:text="가장 가까운 주변 시설 조회"
        app:layout_constraintTop_toBottomOf="@+id/cds_location"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintLeft_toRightOf="@+id/cds_findNearLocation"
        android:layout_marginTop="10dp"
        android:background="@drawable/edge"
        android:textColor="#000000"
        android:textStyle="bold"
        android:gravity="center_horizontal|center_vertical"/>

    <fragment
        android:id="@+id/map"
        android:layout_width="match_parent"
        android:layout_height="200dp"
        android:name="com.google.android.gms.maps.SupportMapFragment"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginTop="130dp"/>

    <ListView
        android:id="@+id/listCds"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:listitem="@layout/item_listview"
        android:layout_marginTop="330dp"
        android:divider="#dedede"
        android:dividerHeight="1.00dp"/>



</androidx.constraintlayout.widget.ConstraintLayout>